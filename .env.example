# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.


# ENTREZ_EMAIL: Your email address, required by NCBI when using the Entrez API. No account is needed — NCBI uses this to contact you if your script causes issues.
ENTREZ_EMAIL="your_email@example.com"

# TROPICOS_API_KEY: Your free API key for the Tropicos API. You can obtain one by registering at https://services.tropicos.org/help?requestkey.
TROPICOS_API_KEY=000-0000-0000-0000

# APIS_PIPE_VERBOSE: Set to "true" to print debug traces from scripts/apis_pipe,
# including warnings when a fetch call returns blank/empty data. Off by default.
APIS_PIPE_VERBOSE=false